{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": "src",
    "outDir": "dist",
    "types": ["node", "electron"],
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "experimentalDecorators": false,
    "emitDecoratorMetadata": false
  },
  "include": ["src/main/**/*.ts", "src/preload/**/*.ts"]
}
