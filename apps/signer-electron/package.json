{
  "name": "@pm-quant/signer-electron",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main/main.js",
  "scripts": {
    "build": "corepack pnpm run build:main && corepack pnpm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "dev": "concurrently -k \"corepack pnpm run dev:main\" \"corepack pnpm run dev:renderer\" \"corepack pnpm run dev:electron\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite --port 5174",
    "dev:electron": "wait-on tcp:5174 file:dist/main/main.js && electron dist/main/main.js"
  },
  "dependencies": {
    "@pm-quant/shared": "workspace:*",
    "ethers": "^6.15.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.33",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "electron": "^35.0.2",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  }
}
